            bool debug_validate_ordering() const
            {
                epoch_read_section_guard read_guard(this);

                for (int level = MAX_LEVELS; level >= 0; --level)
                {
                    SkipNode *current_node = head;
                    KeyType last_key = current_node->key;
                    uint32_t visited_steps = 0;

                    while (true)
                    {
                        bool is_tombstoned = false;
                        SkipNode *next = current_node->next_node[level].get(is_tombstoned);

                        while ((next != NIL) && is_tombstoned)
                        {
                            if (++visited_steps > DEBUG_MAX_VALIDATION_STEPS)
                            {
                                return false;
                            }

                            current_node = next;
                            next = current_node->next_node[level].get(is_tombstoned);
                        }

                        if (next == NIL)
                        {
                            break;
                        }

                        if (++visited_steps > DEBUG_MAX_VALIDATION_STEPS)
                        {
                            return false;
                        }

                        if (next->key < last_key)
                        {
                            return false;
                        }

                        last_key = next->key;
                        current_node = next;
                    }

                    if (NIL->key < last_key)
                    {
                        return false;
                    }
                }

                return true;
            }
#endif

        private:
            SkipNode *head;
            SkipNode *NIL;
            mutable slot_policy_type slot_policy_{};
            mutable epoch_reclaimer_type epoch_reclaimer_;

            int random_level()
            {
                const size_t slot = current_cpu_slot();
                uint64_t state = slot_policy_.slot(slot).load_rng_state();

                int new_level = 1;

                while (true)
                {
                    state ^= (state << 13);
                    state ^= (state >> 7);
                    state ^= (state << 17);

                    if ((state & 1ull) != 0ull)
                    {
                        break;
                    }

                    ++new_level;

                    if (new_level >= MAX_LEVELS)
                    {
                        break;
                    }
                }

                slot_policy_.slot(slot).store_rng_state(state);

                return new_level;
            }

            enum class FindResult
            {
                FOUND,
                NOT_FOUND
            };

            void backoff(uint32_t &backoff_state, size_t cpu_slot)
            {
                uint64_t state = slot_policy_.slot(cpu_slot).load_rng_state();

                state ^= (state << 13);
                state ^= (state >> 7);
                state ^= (state << 17);

                slot_policy_.slot(cpu_slot).store_rng_state(state);

                const uint32_t base_spins = (backoff_state < BACKOFF_MAX_RELAX_SPINS) ? backoff_state : BACKOFF_MAX_RELAX_SPINS;
                const uint32_t jitter_spins = static_cast<uint32_t>(state & 0x3u);
                const uint32_t relax_spins = ((base_spins + jitter_spins) < BACKOFF_MAX_RELAX_SPINS) ? (base_spins + jitter_spins) : BACKOFF_MAX_RELAX_SPINS;

                for (uint32_t spin = 0; spin < relax_spins; ++spin)
                {
                    pmr::platform::cpu_relax();
                }

                if (backoff_state < BACKOFF_MAX_RELAX_SPINS)
                {
                    ++backoff_state;
                }
            }

            void retire_node(SkipNode *node, size_t cpu_slot)
            {
                bool expected_not_enqueued = false;

                if (!node->retirement_enqueued_.compare_exchange_strong(expected_not_enqueued, true, memory_order_acq_rel, memory_order_acquire))
                {
                    return;
                }

                node->retired_epoch_ = epoch_reclaimer_.current_epoch();

                // Push to per-CPU retired list. Using a CAS loop for correctness on
                // test/Linux environments where thread migration can cause two logical
                // threads to share the same CPU slot briefly. On bare-metal (one thread
                // per CPU), the CAS succeeds first-try with zero contention.
                auto &slot = slot_policy_.slot(cpu_slot);
                SkipNode *old_head = slot.local_retired_head_.load(memory_order_relaxed);
                do
                {
                    node->retired_next = old_head;
                } while (!slot.local_retired_head_.compare_exchange_weak(old_head, node, memory_order_release, memory_order_relaxed));
            }

            size_t current_cpu_slot() const
            {
                return slot_policy_.acquire_slot();
            }

            public:
            size_t enter_read_section() const
            {
                return epoch_reclaimer_.enter_read_section();
            }

            void exit_read_section(size_t slot) const
            {
                epoch_reclaimer_.exit_read_section(slot);
            }

            bool try_advance_epoch(size_t exempt_slot)
            {
                return epoch_reclaimer_.try_advance_epoch(exempt_slot);
            }

            uint32_t reclaim_detached_retired_list(size_t cpu_slot, SkipNode *current, uint64_t reclaim_epoch)
            {
                auto &slot = slot_policy_.slot(cpu_slot);

                uint32_t nodes_freed = 0;
                SkipNode *retained_head = nullptr;

                while (current != nullptr)
                {
                    SkipNode *next = current->retired_next;
                    const bool fully_unlinked = (current->unlink_state_.load(memory_order_acquire) == static_cast<uint8_t>(unlink_state::FULLY_UNLINKED));

                    if (fully_unlinked && (current->retired_epoch_ <= reclaim_epoch))
                    {
                        delete current;
                        ++nodes_freed;
                    }
                    else
                    {
                        current->retired_next = retained_head;
                        retained_head = current;
                    }

                    current = next;
                }

                // Put retained nodes back at the front of this CPU's retired list.
                if (retained_head != nullptr)
                {
                    SkipNode *tail = retained_head;
                    while (tail->retired_next != nullptr)
                    {
                        tail = tail->retired_next;
                    }

                    SkipNode *current_head = slot.local_retired_head_.load(memory_order_relaxed);
                    do
                    {
                        tail->retired_next = current_head;
                    } while (!slot.local_retired_head_.compare_exchange_weak(current_head, retained_head, memory_order_release, memory_order_relaxed));
                }

                return nodes_freed;
            }

            pair<uint32_t, bool> advance_and_reclaim(size_t cpu_slot)
            {
                return epoch_reclaimer_.advance_and_reclaim(
                    cpu_slot,
                    [this](size_t reclaim_slot) {
                        return slot_policy_.slot(reclaim_slot).local_retired_head_.exchange(nullptr, memory_order_acq_rel);
                    },
                    [this](size_t reclaim_slot, SkipNode *detached_head, uint64_t reclaim_epoch) {
                        return reclaim_detached_retired_list(reclaim_slot, detached_head, reclaim_epoch);
                    }
                );
            }

            void reclaim_all_retired_nodes()
            {
                for (size_t i = 0; i < NumCPUs; ++i)
                {
                    SkipNode *node = slot_policy_.slot(i).local_retired_head_.exchange(nullptr, memory_order_acq_rel);

                    while (node != nullptr)
                    {
                        SkipNode *next = node->retired_next;
                        delete node;
                        node = next;
                    }
                }
            }

            FindResult find_with_nodelists(const KeyType search_key, SkipNode **preds, SkipNode **succs, size_t cpu_slot)
            {
                bool is_tombstoned = false;

                SkipNode *pred, *curr, *succ;

                pred = head;
                for (auto level = MAX_LEVELS; level >= 0; --level)
                {
                    curr = pred->next_node[level].get_reference();
                    while (true)
                    {
                        if (curr == nullptr)
                        {
                            // Corrupted/null link observed; treat as end-of-list sentinel.
                            curr = NIL;
                            break;
                        }

                        //  Skip over soft deleted nodes

                        succ = curr->next_node[level].get(is_tombstoned);

                        while (is_tombstoned)
                        {
                            SkipNode *tombstoned_node = curr;

                            curr = succ;

                            if (curr == nullptr)
                            {
                                curr = NIL;
                                is_tombstoned = false;
                                break;
                            }

                            succ = curr->next_node[level].get(is_tombstoned);

                            if (level > 0)
                            {
                                if (pred->next_node[level].compare_exchange_strong(tombstoned_node, curr))
                                {
                                    tombstoned_node->upper_levels_remaining_.fetch_sub(1, memory_order_release);
                                }
                            }
                            else
                            {
                                if (tombstoned_node->upper_levels_remaining_.load(memory_order_acquire) <= 0)
                                {
                                    if (pred->next_node[0].compare_exchange_strong(tombstoned_node, curr))
                                    {
                                        tombstoned_node->unlink_state_.store(static_cast<uint8_t>(unlink_state::FULLY_UNLINKED), memory_order_release);
                                        retire_node(tombstoned_node, cpu_slot);
                                    }
                                }
                            }
                        }

                        if (curr->key < search_key)
                        {
                            pred = curr;
                            curr = succ;
                        }
                        else
                        {
                            break;
                        }
                    }

                    preds[level] = pred;
                    succs[level] = curr;
                }

                return ((curr != nullptr) && (curr->key == search_key)) ? FindResult::FOUND : FindResult::NOT_FOUND;
            }

        };
