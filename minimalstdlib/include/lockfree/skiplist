        struct TransactionId : strong_type<uint64_t, TransactionId>
        {
        };

        constexpr TransactionId NOT_TOMBSTONED = TransactionId(0);
        constexpr TransactionId HEAD = TransactionId(1);
        constexpr TransactionId TAIL = TransactionId(2);
        constexpr TransactionId FIRST_USER_TRANSACTION = TransactionId(3);

        //  Embedded atomic forward link: packs pointer + tombstone + ABA counter
        //  into a single 64-bit atomic word, eliminating heap allocation and spin
        //  locks from the CAS path.
        //
        //  Layout (64 bits):
        //    Bit  63       : tombstone flag
        //    Bits 62-48    : 15-bit ABA counter
        //    Bits 47-0     : node pointer (48-bit address space)

        template <typename T>
        struct atomic_forward_link
        {
        private:
            static constexpr uint64_t TOMBSTONE_BIT = uint64_t{1} << 63;
            static constexpr int      ABA_SHIFT     = 48;
            static constexpr uint64_t POINTER_MASK  = (uint64_t{1} << 48) - 1;

            static uint64_t pack(T *ptr, uint16_t aba, bool tombstoned)
            {
                uint64_t v = reinterpret_cast<uint64_t>(ptr) & POINTER_MASK;
                v |= static_cast<uint64_t>(aba & 0x7FFF) << ABA_SHIFT;
                if (tombstoned) v |= TOMBSTONE_BIT;
                return v;
            }

            static T *unpack_ptr(uint64_t v)
            {
                return reinterpret_cast<T *>(static_cast<uintptr_t>(v & POINTER_MASK));
            }

            static constexpr bool is_tombstoned_val(uint64_t v)
            {
                return (v & TOMBSTONE_BIT) != 0;
            }

            static constexpr uint16_t unpack_aba(uint64_t v)
            {
                return static_cast<uint16_t>((v >> ABA_SHIFT) & 0x7FFF);
            }

        public:
            atomic_forward_link(const atomic_forward_link &) = delete;
            atomic_forward_link &operator=(const atomic_forward_link &) = delete;
            atomic_forward_link(atomic_forward_link &&) = delete;
            atomic_forward_link &operator=(atomic_forward_link &&) = delete;

            atomic_forward_link()
            {
                packed_.store(0, memory_order_relaxed);
            }

            ~atomic_forward_link() = default;

            //  Store a pointer (only for nodes not yet visible to other threads)

            void set(T *ptr, TransactionId)
            {
                packed_.store(pack(ptr, 0, false), memory_order_release);
            }

            //  Load just the pointer

            T *get_reference() const
            {
                return unpack_ptr(packed_.load(memory_order_acquire));
            }

            //  Atomic snapshot of pointer and tombstone state

            T *get(TransactionId &deleted_at_transaction) const
            {
                const uint64_t v = packed_.load(memory_order_acquire);
                deleted_at_transaction = is_tombstoned_val(v) ? TransactionId(1) : NOT_TOMBSTONED;
                return unpack_ptr(v);
            }

            //  Mark this link as tombstoned (CAS loop, preserves pointer)

            void soft_delete(TransactionId)
            {
                while (true)
                {
                    uint64_t current = packed_.load(memory_order_acquire);

                    if (is_tombstoned_val(current))
                    {
                        return;
                    }

                    const uint16_t next_aba = static_cast<uint16_t>(unpack_aba(current) + 1);
                    const uint64_t desired = pack(unpack_ptr(current), next_aba, true);

                    if (packed_.compare_exchange_strong(current, desired, memory_order_acq_rel, memory_order_acquire))
                    {
                        return;
                    }
                }
            }

            //  CAS: succeeds only if current pointer == expected_value and link is
            //  not tombstoned.  On success, atomically sets the pointer to new_value
            //  and optionally marks the link tombstoned (deletion_transaction != NOT_TOMBSTONED).

            bool compare_exchange_strong(T *expected_value, T *new_value, TransactionId deletion_transaction)
            {
                uint64_t current = packed_.load(memory_order_acquire);

                if ((unpack_ptr(current) != expected_value) || is_tombstoned_val(current))
                {
                    return false;
                }

                const bool tomb = (deletion_transaction != NOT_TOMBSTONED);
                const uint16_t next_aba = static_cast<uint16_t>(unpack_aba(current) + 1);
                const uint64_t desired = pack(new_value, next_aba, tomb);

                return packed_.compare_exchange_strong(current, desired, memory_order_acq_rel, memory_order_acquire);
            }

            TransactionId get_deleted_at_transaction() const
            {
                const uint64_t v = packed_.load(memory_order_acquire);
                return is_tombstoned_val(v) ? TransactionId(1) : NOT_TOMBSTONED;
            }

            TransactionId get_inserted_at_transaction() const
            {
                return NOT_TOMBSTONED;
            }

        private:
            atomic<uint64_t> packed_;
        };

        template <typename KeyType, typename ValueType, int32_t MAX_LEVELS = DEFAULT_MAX_LEVELS> //  MAX_LEVELS must be signed as we need to iterated down to and include index 0
        class SkipList
        {
        private:
            static constexpr uint32_t MAX_INSERT_LEVEL0_RETRIES = 1024;
            static constexpr uint32_t MAX_INSERT_UPPER_LEVEL_RETRIES = 256;
            static constexpr uint32_t MAX_REMOVE_MARK_RETRIES_PER_LEVEL = 256;
            static constexpr uint32_t MAX_REMOVE_BOTTOM_RETRIES = 1024;
            static constexpr uint32_t GC_MAX_SCAN_STEPS = 5000000;
            static constexpr uint32_t BACKOFF_MAX_RELAX_SPINS = 32;
            static constexpr size_t MAX_EPOCH_CPUS = 256;
            static constexpr uint32_t INVALID_CPU_ID = std::numeric_limits<uint32_t>::max();
            static constexpr uint64_t EPOCH_RECLAIM_LAG = 2;
#ifdef __MINIMAL_STD_TEST__
            static constexpr uint32_t DEBUG_MAX_VALIDATION_STEPS = 1000000;
#endif

            constexpr bool tombstoned(TransactionId deleted_at_transaction) const
            {
                return deleted_at_transaction != NOT_TOMBSTONED;
            }

            enum class unlink_state : uint8_t
            {
                ACTIVE,
                FULLY_UNLINKED
            };

            struct SkipNode
            {
                // Constructor for standard nodes
                SkipNode(const KeyType k, const ValueType &v, const int next_node_size) : key(k), value(v), top_level(next_node_size)
                {
                    intialize_next_nodes(next_node_size, nullptr);
                }

                // Constructor for sentinel nodes head and NIL
                SkipNode(const KeyType k, const int next_node_size, SkipNode *next_node_target) : key(k), top_level(next_node_size)
                {
                    intialize_next_nodes(next_node_size, next_node_target);
                }

                ~SkipNode()
                {
                }

                SkipNode(const SkipNode &) = delete;
                SkipNode &operator=(const SkipNode &) = delete;
                SkipNode(SkipNode &&) = delete;
                SkipNode &operator=(SkipNode &&) = delete;

                void intialize_next_nodes(const int next_node_size, SkipNode *next_node_target)
                {
                    for (auto i = 0; i != next_node_size; ++i)
                    {
                        next_node[i].set(next_node_target, NOT_TOMBSTONED);
                    }
                }

                KeyType key;
                ValueType value;

                int top_level;

                // Forward links: each packs pointer + tombstone + ABA in 64 bits

                array<atomic_forward_link<SkipNode>, MAX_LEVELS + 1> next_node;
                SkipNode *retired_next = nullptr;
                atomic<bool> retirement_enqueued_{false};
                atomic<uint8_t> unlink_state_{static_cast<uint8_t>(unlink_state::ACTIVE)};
                atomic<int32_t> upper_levels_remaining_{0};
                uint64_t retired_epoch_ = 0;
            };

            struct epoch_reader_state
            {
                atomic<bool> active_{false};
                atomic<uint64_t> epoch_{0};
                atomic<uint32_t> read_depth_{0};
            };

            struct epoch_read_section_guard
            {
                explicit epoch_read_section_guard(const SkipList *list)
                    : list_(list)
                {
                    cpu_slot_ = list_->enter_read_section();
                }

                ~epoch_read_section_guard()
                {
                    list_->exit_read_section(cpu_slot_);
                }

                const SkipList *list_;
                size_t cpu_slot_ = 0;
            };

        public:

        using key_type = KeyType;
        using value_type = ValueType;
        
        using allocator_type = allocator<value_type>;

#ifdef __MINIMAL_STD_TEST__
            struct contention_counters
            {
                uint64_t insert_level0_cas_failures = 0;
                uint64_t insert_upper_level_cas_failures = 0;
                uint64_t remove_mark_retries = 0;
                uint64_t remove_bottom_cas_failures = 0;
                uint64_t find_tombstone_skips = 0;
            };
#endif

            SkipList()
            {
                for (size_t i = 0; i < MAX_EPOCH_CPUS; ++i)
                {
                    epoch_slot_cpu_ids_[i].store(INVALID_CPU_ID, memory_order_relaxed);
                    level_rng_states_[i].store(0x9e3779b97f4a7c15ull ^ (static_cast<uint64_t>(i) * 0xbf58476d1ce4e5b9ull), memory_order_relaxed);
                }

                NIL = new SkipNode(std::numeric_limits<KeyType>::max(), MAX_LEVELS + 1, nullptr);
                head = new SkipNode(std::numeric_limits<KeyType>::min(), MAX_LEVELS + 1, NIL);
            }

            ~SkipList()
            {
                SkipNode *current_node = head->next_node[0].get_reference();

                while (current_node != NIL)
                {
                    SkipNode *next_node = current_node->next_node[0].get_reference();

                    if (!current_node->retirement_enqueued_.load(memory_order_acquire))
                    {
                        delete current_node;
                    }

                    current_node = next_node;
                }

                reclaim_all_abandoned_new_nodes();
                reclaim_all_retired_nodes();

                delete head;
                delete NIL;
            };

            ValueType *find(const KeyType search_key)
            {
                epoch_read_section_guard read_guard(this);

                TransactionId deletion_transaction = NOT_TOMBSTONED;
                SkipNode *pred = head, *curr = nullptr, *succ = nullptr;

                // traverse from top of head
                for (int level = MAX_LEVELS; level >= 0; --level)
                {
                    curr = pred->next_node[level].get_reference();

                    while (true)
                    {
                        succ = curr->next_node[level].get(deletion_transaction);

                        while (tombstoned(deletion_transaction))
                        {
                            SkipNode *tombstoned_node = curr;
                            curr = curr->next_node[level].get_reference();
                            succ = curr->next_node[level].get(deletion_transaction);

                            if (level > 0)
                            {
                                //  Upper level: CAS out the tombstone and decrement
                                //  the counter so level-0 knows when it's safe.

                                if (pred->next_node[level].compare_exchange_strong(tombstoned_node, curr, NOT_TOMBSTONED))
                                {
                                    tombstoned_node->upper_levels_remaining_.fetch_sub(1, memory_order_acq_rel);
                                }
                            }
                            else
                            {
                                //  Level 0: unlink only when all upper levels are done.

                                if (tombstoned_node->upper_levels_remaining_.load(memory_order_acquire) <= 0)
                                {
                                    if (pred->next_node[0].compare_exchange_strong(tombstoned_node, curr, NOT_TOMBSTONED))
                                    {
                                        tombstoned_node->unlink_state_.store(static_cast<uint8_t>(unlink_state::FULLY_UNLINKED), memory_order_release);
                                        retire_node(tombstoned_node);
                                    }
                                }
                            }
                        }

                        //  Move down the skip list

                        if (curr->key < search_key)
                        {
                            pred = curr;
                            curr = succ;
                        }
                        else
                        {
                            break;
                        }
                    }
                }

                return (curr->key == search_key ? &curr->value : nullptr);
            }

            uint32_t gc()
            {
                epoch_read_section_guard read_guard(this);

                uint32_t nodes_removed = 0;

                TransactionId deletion_transaction = NOT_TOMBSTONED;

                SkipNode *pred = head;
                SkipNode *curr = pred->next_node[0].get_reference();
                uint32_t scan_steps = 0;

                while (curr != NIL)
                {
                    if (++scan_steps > GC_MAX_SCAN_STEPS)
                    {
                        break;
                    }

                    SkipNode *succ = curr->next_node[0].get(deletion_transaction);

                    if (tombstoned(deletion_transaction))
                    {
                        unlink_tombstoned_node_upper_levels(curr);

                        if (curr->upper_levels_remaining_.load(memory_order_acquire) <= 0)
                        {
                            if (pred->next_node[0].compare_exchange_strong(curr, succ, NOT_TOMBSTONED))
                            {
                                curr->unlink_state_.store(static_cast<uint8_t>(unlink_state::FULLY_UNLINKED), memory_order_release);
                                nodes_removed++;
                                retire_node(curr);
                            }
                        }

                        curr = pred->next_node[0].get_reference();
                        continue;
                    }

                    pred = curr;
                    curr = succ;
                }

                advance_epoch_and_reclaim_retired_nodes(read_guard.cpu_slot_);

                return nodes_removed;
            }

            bool insert(const KeyType key, const ValueType &value)
            {
                epoch_read_section_guard read_guard(this);

                const TransactionId transaction_id = cpu_transaction_id(read_guard.cpu_slot_);
                uint32_t insert_level0_retry_count = 0;
                uint32_t insert_level0_backoff = 0;
                uint32_t insert_upper_level_backoff = 0;

                int top_level = random_level();

                SkipNode *preds[MAX_LEVELS + 1];
                SkipNode *succs[MAX_LEVELS + 1];

                while (true)
                {
                    FindResult found = find_with_nodelists(key, preds, succs);

                    if ((found == FindResult::FOUND) || (found == FindResult::SOFT_DELETED))
                    {
                        return false;
                    }
                    else
                    {
                        auto new_node = new SkipNode(key, value, top_level);

                        for (auto level = 1; level < top_level; ++level)
                        {
                            auto succ = succs[level];
                            new_node->next_node[level].set(succ, transaction_id);
                        }

                        auto pred = preds[0];
                        auto succ = succs[0];

                        new_node->next_node[0].set(succ, transaction_id);

                        if (!pred->next_node[0].compare_exchange_strong(succ, new_node, NOT_TOMBSTONED))
                        {
                            abandon_new_node(new_node);

#ifdef __MINIMAL_STD_TEST__
                            insert_level0_cas_failures_.fetch_add(1, memory_order_relaxed);
#endif

                            ++insert_level0_retry_count;

                            if (insert_level0_retry_count >= MAX_INSERT_LEVEL0_RETRIES)
                            {
                                return false;
                            }

                            backoff(insert_level0_backoff);

                            continue; // CAS failed, try again
                        }

                        insert_level0_backoff = 0;

                        for (auto level = 1; level < top_level; ++level)
                        {
                            uint32_t upper_level_retry_count = 0;

                            while (true)
                            {
                                pred = preds[level];
                                succ = succs[level];

                                if (pred->next_node[level].compare_exchange_strong(succ, new_node, NOT_TOMBSTONED))
                                {
                                    new_node->upper_levels_remaining_.fetch_add(1, memory_order_release);
                                    insert_upper_level_backoff = 0;
                                    break;
                                }

#ifdef __MINIMAL_STD_TEST__
                                insert_upper_level_cas_failures_.fetch_add(1, memory_order_relaxed);
#endif

                                ++upper_level_retry_count;

                                if (upper_level_retry_count >= MAX_INSERT_UPPER_LEVEL_RETRIES)
                                {
                                    break;
                                }

                                backoff(insert_upper_level_backoff);

                                find_with_nodelists(key, preds, succs); // CAS failed for upper level, search node to update preds and succs
                            }
                        }

                        return true;
                    }
                }
            }

            bool remove(const KeyType key)
            {
                epoch_read_section_guard read_guard(this);

                const TransactionId transaction_id = cpu_transaction_id(read_guard.cpu_slot_);

                SkipNode *preds[MAX_LEVELS + 1];
                SkipNode *succs[MAX_LEVELS + 1];
                SkipNode *succ;

            RETRY_REMOVE:
                while (true)
                {
                    FindResult found = find_with_nodelists(key, preds, succs);

                    if (found != FindResult::FOUND)
                    {
                        return false; // nothing to delete
                    }
                    else
                    {
                        auto node_to_remove = succs[0];

                        //  Mark as deleted on higher levels

                        TransactionId deletion_transaction = NOT_TOMBSTONED;

                        for (auto level = node_to_remove->top_level - 1; level >= 1; --level)
                        {
                            succ = node_to_remove->next_node[level].get(deletion_transaction);
                            uint32_t mark_retry_count = 0;
                            uint32_t mark_retry_backoff = 0;

                            while (!tombstoned(deletion_transaction))
                            {
                                node_to_remove->next_node[level].soft_delete(transaction_id);
                                succ = node_to_remove->next_node[level].get(deletion_transaction);

#ifdef __MINIMAL_STD_TEST__
                                remove_mark_retries_.fetch_add(1, memory_order_relaxed);
#endif

                                ++mark_retry_count;

                                if (mark_retry_count >= MAX_REMOVE_MARK_RETRIES_PER_LEVEL)
                                {
                                    goto RETRY_REMOVE;
                                }

                                backoff(mark_retry_backoff);
                            }
                        }

                        //  Bottom level

                        deletion_transaction = NOT_TOMBSTONED;
                        succ = node_to_remove->next_node[0].get(deletion_transaction);
                        uint32_t bottom_retry_count = 0;
                        uint32_t bottom_retry_backoff = 0;

                        while (true)
                        {
                            bool success = node_to_remove->next_node[0].compare_exchange_strong(succ, succ, transaction_id);
                            succ = succs[0]->next_node[0].get(deletion_transaction);

                            if (success)
                            {
                                // this thread soft deleted the node

                                try_advance_epoch(read_guard.cpu_slot_);

                                return true;
                            }
                            else if (tombstoned(deletion_transaction))
                            {
                                // another thread already soft deleted the node

                                return false;
                            }

#ifdef __MINIMAL_STD_TEST__
                            remove_bottom_cas_failures_.fetch_add(1, memory_order_relaxed);
#endif

                            ++bottom_retry_count;

                            if (bottom_retry_count >= MAX_REMOVE_BOTTOM_RETRIES)
                            {
                                goto RETRY_REMOVE;
                            }

                            backoff(bottom_retry_backoff);
                        }
                    }
                }
            }

            uint32_t size() const
            {
                epoch_read_section_guard read_guard(this);

                auto current_node = head->next_node[0].get_reference();

                uint32_t size = 0;
                TransactionId node_deletion_transaction = NOT_TOMBSTONED;

                while (current_node->key != std::numeric_limits<KeyType>::max())
                {
                    current_node->next_node[0].get(node_deletion_transaction);

                    if (!tombstoned(node_deletion_transaction))
                    {
                        ++size;
                    }

                    current_node = current_node->next_node[0].get_reference();
                }

                return size;
            }

#ifdef __MINIMAL_STD_TEST__
            contention_counters debug_get_contention_counters() const
            {
                contention_counters counters;

                counters.insert_level0_cas_failures = insert_level0_cas_failures_.load(memory_order_relaxed);
                counters.insert_upper_level_cas_failures = insert_upper_level_cas_failures_.load(memory_order_relaxed);
                counters.remove_mark_retries = remove_mark_retries_.load(memory_order_relaxed);
                counters.remove_bottom_cas_failures = remove_bottom_cas_failures_.load(memory_order_relaxed);
                counters.find_tombstone_skips = find_tombstone_skips_.load(memory_order_relaxed);

                return counters;
            }

            bool debug_validate_ordering() const
            {
                epoch_read_section_guard read_guard(this);

                for (int level = MAX_LEVELS; level >= 0; --level)
                {
                    SkipNode *current_node = head;
                    KeyType last_key = current_node->key;
                    uint32_t visited_steps = 0;

                    while (true)
                    {
                        TransactionId deletion_transaction = NOT_TOMBSTONED;
                        SkipNode *next = current_node->next_node[level].get(deletion_transaction);

                        while ((next != NIL) && tombstoned(deletion_transaction))
                        {
                            if (++visited_steps > DEBUG_MAX_VALIDATION_STEPS)
                            {
                                return false;
                            }

                            current_node = next;
                            next = current_node->next_node[level].get(deletion_transaction);
                        }

                        if (next == NIL)
                        {
                            break;
                        }

                        if (++visited_steps > DEBUG_MAX_VALIDATION_STEPS)
                        {
                            return false;
                        }

                        if (next->key < last_key)
                        {
                            return false;
                        }

                        last_key = next->key;
                        current_node = next;
                    }

                    if (NIL->key < last_key)
                    {
                        return false;
                    }
                }

                return true;
            }
#endif

        private:
            SkipNode *head;
            SkipNode *NIL;
            atomic<SkipNode *> retired_nodes_head_{nullptr};
            atomic<SkipNode *> abandoned_new_nodes_head_{nullptr};
            mutable atomic<bool> retired_nodes_lock_{false};
            mutable array<epoch_reader_state, MAX_EPOCH_CPUS> epoch_reader_states_{};
            mutable array<atomic<uint32_t>, MAX_EPOCH_CPUS> epoch_slot_cpu_ids_{};
            mutable atomic<uint64_t> global_epoch_{1};
#ifdef __MINIMAL_STD_TEST__
            mutable atomic<uint64_t> insert_level0_cas_failures_{0};
            mutable atomic<uint64_t> insert_upper_level_cas_failures_{0};
            mutable atomic<uint64_t> remove_mark_retries_{0};
            mutable atomic<uint64_t> remove_bottom_cas_failures_{0};
            mutable atomic<uint64_t> find_tombstone_skips_{0};
#endif

            mutable array<atomic<uint64_t>, MAX_EPOCH_CPUS> level_rng_states_{};

            static TransactionId cpu_transaction_id(size_t cpu_slot)
            {
                return TransactionId{static_cast<uint64_t>(cpu_slot) + static_cast<uint64_t>(FIRST_USER_TRANSACTION)};
            }

            int random_level()
            {
                const size_t slot = current_cpu_slot();
                uint64_t state = level_rng_states_[slot].load(memory_order_relaxed);

                int new_level = 1;

                while (true)
                {
                    state ^= (state << 13);
                    state ^= (state >> 7);
                    state ^= (state << 17);

                    if ((state & 1ull) != 0ull)
                    {
                        break;
                    }

                    ++new_level;

                    if (new_level >= MAX_LEVELS)
                    {
                        break;
                    }
                }

                level_rng_states_[slot].store(state, memory_order_relaxed);

                return new_level;
            }

            enum class FindResult
            {
                FOUND,
                NOT_FOUND,
                SOFT_DELETED
            };

            static void spin_lock(atomic<bool> &lock)
            {
                bool expected_unlocked = false;

                while (!lock.compare_exchange_strong(expected_unlocked, true, memory_order_acquire))
                {
                    expected_unlocked = false;
                }
            }

            static void spin_unlock(atomic<bool> &lock)
            {
                lock.store(false, memory_order_release);
            }

            static void backoff(uint32_t &backoff_state)
            {
                const uint32_t relax_spins = (backoff_state < BACKOFF_MAX_RELAX_SPINS) ? backoff_state : BACKOFF_MAX_RELAX_SPINS;

                for (uint32_t spin = 0; spin < relax_spins; ++spin)
                {
                    pmr::platform::cpu_relax();
                }

                if (backoff_state < BACKOFF_MAX_RELAX_SPINS)
                {
                    ++backoff_state;
                }
            }

            void retire_node(SkipNode *node)
            {
                bool expected_not_enqueued = false;

                if (!node->retirement_enqueued_.compare_exchange_strong(expected_not_enqueued, true, memory_order_acq_rel, memory_order_acquire))
                {
                    return;
                }

                node->retired_epoch_ = global_epoch_.load(memory_order_acquire);

                spin_lock(retired_nodes_lock_);
                node->retired_next = retired_nodes_head_.load(memory_order_relaxed);
                retired_nodes_head_.store(node, memory_order_release);
                spin_unlock(retired_nodes_lock_);
            }

            size_t current_cpu_slot() const
            {
                const uint32_t cpu_id = pmr::platform::get_cpu_id();

                const size_t initial_slot = static_cast<size_t>(cpu_id) % MAX_EPOCH_CPUS;

                for (size_t probe = 0; probe < MAX_EPOCH_CPUS; ++probe)
                {
                    const size_t slot = (initial_slot + probe) % MAX_EPOCH_CPUS;

                    uint32_t expected_unassigned = INVALID_CPU_ID;

                    if (epoch_slot_cpu_ids_[slot].compare_exchange_strong(expected_unassigned, cpu_id, memory_order_acq_rel, memory_order_acquire))
                    {
                        return slot;
                    }

                    const uint32_t assigned_cpu = epoch_slot_cpu_ids_[slot].load(memory_order_acquire);

                    if (assigned_cpu == cpu_id)
                    {
                        return slot;
                    }
                }

                return initial_slot;
            }

            size_t enter_read_section() const
            {
                const size_t slot = current_cpu_slot();

                const uint32_t previous_depth = epoch_reader_states_[slot].read_depth_.fetch_add(1, memory_order_acq_rel);

                if (previous_depth == 0)
                {
                    const uint64_t current_epoch = global_epoch_.load(memory_order_acquire);
                    epoch_reader_states_[slot].epoch_.store(current_epoch, memory_order_release);
                    epoch_reader_states_[slot].active_.store(true, memory_order_release);
                }

                return slot;
            }

            void exit_read_section(size_t slot) const
            {
                uint32_t current_depth = epoch_reader_states_[slot].read_depth_.load(memory_order_acquire);

                while (true)
                {
                    if (current_depth == 0)
                    {
                        return;
                    }

                    const uint32_t next_depth = current_depth - 1;

                    if (epoch_reader_states_[slot].read_depth_.compare_exchange_strong(current_depth, next_depth, memory_order_acq_rel, memory_order_acquire))
                    {
                        if (next_depth == 0)
                        {
                            epoch_reader_states_[slot].active_.store(false, memory_order_release);
                        }

                        return;
                    }
                }
            }

            bool try_advance_epoch(size_t exempt_slot)
            {
                uint64_t current_epoch = global_epoch_.load(memory_order_acquire);

                for (size_t i = 0; i < MAX_EPOCH_CPUS; ++i)
                {
                    if (i == exempt_slot)
                    {
                        continue;
                    }

                    if (!epoch_reader_states_[i].active_.load(memory_order_acquire))
                    {
                        continue;
                    }

                    const uint64_t reader_epoch = epoch_reader_states_[i].epoch_.load(memory_order_acquire);

                    if (reader_epoch <= current_epoch)
                    {
                        return false;
                    }
                }

                return global_epoch_.compare_exchange_strong(current_epoch, current_epoch + 1, memory_order_seq_cst);
            }

            void reclaim_retired_nodes_by_epoch()
            {
                uint64_t current_epoch = global_epoch_.load(memory_order_acquire);

                if (current_epoch <= EPOCH_RECLAIM_LAG)
                {
                    return;
                }

                const uint64_t reclaim_epoch = current_epoch - EPOCH_RECLAIM_LAG;

                spin_lock(retired_nodes_lock_);
                SkipNode *retired_list = retired_nodes_head_.exchange(nullptr, memory_order_acq_rel);
                spin_unlock(retired_nodes_lock_);

                SkipNode *retained_list = nullptr;
                SkipNode *reclaim_list = nullptr;

                while (retired_list != nullptr)
                {
                    SkipNode *next = retired_list->retired_next;
                    const bool reclaim_eligible = (retired_list->unlink_state_.load(memory_order_acquire) == static_cast<uint8_t>(unlink_state::FULLY_UNLINKED));

                    if (reclaim_eligible && (retired_list->retired_epoch_ <= reclaim_epoch))
                    {
                        retired_list->retired_next = reclaim_list;
                        reclaim_list = retired_list;
                    }
                    else
                    {
                        retired_list->retired_next = retained_list;
                        retained_list = retired_list;
                    }

                    retired_list = next;
                }

                if (retained_list != nullptr)
                {
                    spin_lock(retired_nodes_lock_);
                    SkipNode *current_head = retired_nodes_head_.load(memory_order_relaxed);

                    while (retained_list != nullptr)
                    {
                        SkipNode *next = retained_list->retired_next;
                        retained_list->retired_next = current_head;
                        current_head = retained_list;
                        retained_list = next;
                    }

                    retired_nodes_head_.store(current_head, memory_order_release);
                    spin_unlock(retired_nodes_lock_);
                }

                while (reclaim_list != nullptr)
                {
                    SkipNode *next = reclaim_list->retired_next;
                    delete reclaim_list;
                    reclaim_list = next;
                }
            }

            void advance_epoch_and_reclaim_retired_nodes(size_t exempt_slot)
            {
                (void)try_advance_epoch(exempt_slot);
                reclaim_retired_nodes_by_epoch();
            }

            void reclaim_all_retired_nodes()
            {
                spin_lock(retired_nodes_lock_);
                SkipNode *node = retired_nodes_head_.exchange(nullptr, memory_order_acq_rel);
                spin_unlock(retired_nodes_lock_);

                while (node != nullptr)
                {
                    SkipNode *next = node->retired_next;
                    delete node;
                    node = next;
                }
            }

            void abandon_new_node(SkipNode *node)
            {
                SkipNode *old_head = abandoned_new_nodes_head_.load(memory_order_relaxed);

                do
                {
                    node->retired_next = old_head;
                } while (!abandoned_new_nodes_head_.compare_exchange_weak(old_head, node, memory_order_release, memory_order_relaxed));
            }

            void reclaim_all_abandoned_new_nodes()
            {
                SkipNode *node = abandoned_new_nodes_head_.exchange(nullptr, memory_order_acq_rel);

                while (node != nullptr)
                {
                    SkipNode *next = node->retired_next;
                    delete node;
                    node = next;
                }
            }

            FindResult find_with_nodelists(const KeyType search_key, SkipNode **preds, SkipNode **succs)
            {
                TransactionId deletion_transaction = NOT_TOMBSTONED;
                bool soft_deleted = false;

                SkipNode *pred, *curr, *succ;

                pred = head;
                for (auto level = MAX_LEVELS; level >= 0; --level)
                {
                    curr = pred->next_node[level].get_reference();
                    while (true)
                    {
                        //  Skip over soft deleted nodes

                        succ = curr->next_node[level].get(deletion_transaction);

                        while (tombstoned(deletion_transaction))
                        {
#ifdef __MINIMAL_STD_TEST__
                            find_tombstone_skips_.fetch_add(1, memory_order_relaxed);
#endif

                            if (curr->key == search_key)
                            {
                                soft_deleted = true;
                                break;
                            }
                            curr = succ;
                            succ = curr->next_node[level].get(deletion_transaction);
                        }

                        if (curr->key < search_key)
                        {
                            pred = curr;
                            curr = succ;
                        }
                        else
                        {
                            break;
                        }
                    }

                    preds[level] = pred;
                    succs[level] = curr;
                }

                if (soft_deleted)
                {
                    return FindResult::SOFT_DELETED;
                }

                return (curr->key == search_key) ? FindResult::FOUND : FindResult::NOT_FOUND;
            }

            bool unlink_tombstoned_node_upper_levels(SkipNode *node)
            {
                if (node == nullptr)
                {
                    return false;
                }

                for (int level = node->top_level - 1; level >= 1; --level)
                {
                    uint32_t scan_steps = 0;
                    uint32_t retry_count = 0;

                RETRY_LEVEL_UNLINK:
                    SkipNode *pred = head;
                    SkipNode *curr = pred->next_node[level].get_reference();
                    TransactionId deletion_transaction = NOT_TOMBSTONED;

                    while ((curr != NIL) && (scan_steps < GC_MAX_SCAN_STEPS))
                    {
                        ++scan_steps;

                        if (curr == node)
                        {
                            SkipNode *succ = curr->next_node[level].get(deletion_transaction);

                            if (pred->next_node[level].compare_exchange_strong(curr, succ, NOT_TOMBSTONED))
                            {
                                node->upper_levels_remaining_.fetch_sub(1, memory_order_acq_rel);
                                break;
                            }

                            ++retry_count;

                            if (retry_count >= MAX_REMOVE_MARK_RETRIES_PER_LEVEL)
                            {
                                return false;
                            }

                            backoff(retry_count);

                            goto RETRY_LEVEL_UNLINK;
                        }

                        if (curr->key > node->key)
                        {
                            break;
                        }

                        SkipNode *next = curr->next_node[level].get(deletion_transaction);

                        //  Skip tombstoned predecessors: a tombstoned node at this level
                        //  has its outgoing link marked, which would cause the CAS to fail
                        //  if it becomes pred.  Advance past it without updating pred.

                        if (!tombstoned(deletion_transaction))
                        {
                            pred = curr;
                        }

                        curr = next;
                    }
                }

                return true;
            }
        };
    }

