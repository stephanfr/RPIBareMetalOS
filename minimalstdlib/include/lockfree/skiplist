        //  Embedded atomic forward link: packs pointer handle + tombstone flag.
        //  into a single 64-bit atomic word, eliminating heap allocation and spin
        //  locks from the CAS path.
        //
        //  Layout (64 bits):
        //    Bit  63       : tombstone flag
        //    Bits 62-32    : 31-bit slot generation
        //    Bits 31-0     : 32-bit slot table index (safe on all ARM64 configurations)

        template <typename T>
        struct atomic_forward_link
        {
        public:
            static constexpr uint32_t SLOTS_PER_BLOCK_SHIFT = 14;
            static constexpr uint32_t SLOTS_PER_BLOCK = 1u << SLOTS_PER_BLOCK_SHIFT; // 16384
            static constexpr uint32_t BLOCK_MASK = SLOTS_PER_BLOCK - 1;
            
            static constexpr uint32_t MAX_BLOCKS = (MINIMAL_STD_SKIPLIST_MAX_SLOTS + SLOTS_PER_BLOCK - 1) / SLOTS_PER_BLOCK;
            static constexpr uint32_t MAX_SLOTS = MAX_BLOCKS * SLOTS_PER_BLOCK;

            struct slot_handle
            {
                uint32_t slot = 0;
                uint32_t generation = 0;
            };

            struct alignas(64) slot_block
            {
                array<atomic<T *>, SLOTS_PER_BLOCK> slot_table_{};
                array<atomic<uint32_t>, SLOTS_PER_BLOCK> free_next_slot_{};
                array<atomic<uint32_t>, SLOTS_PER_BLOCK> slot_generation_{};
                atomic<uint32_t> free_list_head_{0};
                atomic<uint32_t> active_slots_{0};
            };

            static inline atomic<uint32_t> next_free_slot_{1};
            static inline atomic<uint32_t> high_water_slot_{0};
            static inline atomic<uint32_t> high_water_block_{0};
            static inline array<atomic<slot_block*>, MAX_BLOCKS> blocks_{};
            static inline atomic<uint64_t> partially_free_blocks_{0};

            static uint32_t slot_to_block_index(uint32_t slot)
            {
                return slot >> SLOTS_PER_BLOCK_SHIFT;
            }

            static uint32_t slot_to_block_offset(uint32_t slot)
            {
                return slot & BLOCK_MASK;
            }

            static void update_high_water_slot(uint32_t slot)
            {
                uint32_t observed = high_water_slot_.load(memory_order_relaxed);

                while (observed < slot)
                {
                    if (high_water_slot_.compare_exchange_weak(observed, slot, memory_order_relaxed, memory_order_relaxed))
                    {
                        break;
                    }
                }
            }

            static slot_block* ensure_block_installed(uint32_t block_index)
            {
                slot_block* current_block = blocks_[block_index].load(memory_order_acquire);
                if (current_block != nullptr)
                {
                    return current_block;
                }

                slot_block* new_block = new slot_block();

                if (blocks_[block_index].compare_exchange_strong(current_block, new_block, memory_order_release, memory_order_acquire))
                {
                    uint32_t observed_hw = high_water_block_.load(memory_order_relaxed);
                    while (observed_hw < block_index &&
                           !high_water_block_.compare_exchange_weak(observed_hw, block_index, memory_order_relaxed, memory_order_relaxed))
                    {
                    }
                    return new_block;
                }
                else
                {
                    delete new_block;
                    return current_block;
                }
            }

            static slot_handle allocate_slot(T *ptr)
            {
                uint64_t available_blocks = partially_free_blocks_.load(memory_order_acquire);
                
                while (available_blocks != 0)
                {
                    uint32_t block_idx = __builtin_ctzll(available_blocks);
                    
                    slot_block* block = blocks_[block_idx].load(memory_order_acquire);
                    if (block != nullptr)
                    {
                        uint32_t head = block->free_list_head_.load(memory_order_acquire);
                        while (head != 0)
                        {
                            uint32_t offset = slot_to_block_offset(head);
                            const uint32_t next = block->free_next_slot_[offset].load(memory_order_acquire);

                            if (block->free_list_head_.compare_exchange_weak(head, next, memory_order_acq_rel))
                            {
                                if (next == 0)
                                {
                                    partially_free_blocks_.fetch_and(~(1ULL << block_idx), memory_order_release);
                                }

                                block->active_slots_.fetch_add(1, memory_order_relaxed);

                                update_high_water_slot(head);

                                uint32_t generation = block->slot_generation_[offset].load(memory_order_relaxed);
                                generation = (generation + 1u) & GENERATION_MASK;
                                if (generation == 0)
                                {
                                    generation = 1;
                                }

                                block->slot_generation_[offset].store(generation, memory_order_release);
                                block->slot_table_[offset].store(ptr, memory_order_release);
                                return {head, generation};
                            }
                        }
                        
                        if (head == 0)
                        {
                            partially_free_blocks_.fetch_and(~(1ULL << block_idx), memory_order_release);
                        }
                    }
                    else
                    {
                        partially_free_blocks_.fetch_and(~(1ULL << block_idx), memory_order_release);
                    }
                    
                    available_blocks = partially_free_blocks_.load(memory_order_acquire);
                }

                uint32_t idx = next_free_slot_.fetch_add(1, memory_order_acq_rel);
                if (idx < MAX_SLOTS)
                {
                    uint32_t block_idx = slot_to_block_index(idx);
                    uint32_t offset = slot_to_block_offset(idx);
                    
                    slot_block* block = ensure_block_installed(block_idx);

                    block->active_slots_.fetch_add(1, memory_order_relaxed);

                    update_high_water_slot(idx);

                    const uint32_t generation = 1;
                    block->slot_generation_[offset].store(generation, memory_order_release);
                    block->slot_table_[offset].store(ptr, memory_order_release);
                    block->free_next_slot_[offset].store(0, memory_order_relaxed);
                    return {idx, generation};
                }

                return {0, 0};
            }

            static void free_slot(uint32_t slot)
            {
                if ((slot == 0) || (slot >= MAX_SLOTS)) return;

                uint32_t block_idx = slot_to_block_index(slot);
                uint32_t offset = slot_to_block_offset(slot);
                slot_block* block = blocks_[block_idx].load(memory_order_acquire);
                if (block == nullptr) return; // Should not happen for a valid allocated slot

                uint32_t head = block->free_list_head_.load(memory_order_acquire);
                while (true)
                {
                    // Never store freelist metadata in slot_table_. Readers of
                    // unpack_ptr() must only ever observe real node pointers or nullptr.
                    block->slot_table_[offset].store(nullptr, memory_order_release);
                    block->free_next_slot_[offset].store(head, memory_order_release);

                    if (block->free_list_head_.compare_exchange_weak(head, slot, memory_order_acq_rel))
                    {
                        partially_free_blocks_.fetch_or(1ULL << block_idx, memory_order_release);
                        block->active_slots_.fetch_sub(1, memory_order_release);
                        break;
                    }
                }
            }

        private:
            static constexpr uint64_t TOMBSTONE_BIT = uint64_t{1} << 63;
            static constexpr int      GENERATION_SHIFT = 32;
            static constexpr uint32_t GENERATION_MASK = 0x7FFFFFFFu;
            static constexpr uint64_t SLOT_MASK     = (uint64_t{1} << 32) - 1;

            static uint32_t pointer_slot_or_zero(T *ptr)
            {
                if (ptr == nullptr)
                {
                    return 0;
                }

                const uint32_t slot = ptr->internal_slot_;
                if ((slot == 0) || (slot >= MAX_SLOTS))
                {
                    return 0;
                }

                return slot;
            }

            static uint32_t pointer_generation_or_zero(T *ptr)
            {
                if (ptr == nullptr)
                {
                    return 0;
                }

                const uint32_t slot = pointer_slot_or_zero(ptr);
                if (slot == 0)
                {
                    return 0;
                }

                const uint32_t generation = (ptr->internal_generation_ & GENERATION_MASK);
                if (generation == 0)
                {
                    return 0;
                }

                return generation;
            }

            static uint64_t pack_slot_generation(uint32_t slot, uint32_t generation, bool tombstoned)
            {
                uint64_t v = static_cast<uint64_t>(slot) & SLOT_MASK;
                v |= static_cast<uint64_t>(generation & GENERATION_MASK) << GENERATION_SHIFT;
                if (tombstoned) v |= TOMBSTONE_BIT;
                return v;
            }

            static uint64_t pack(T *ptr, bool tombstoned)
            {
                return pack_slot_generation(pointer_slot_or_zero(ptr), pointer_generation_or_zero(ptr), tombstoned);
            }

            static T *unpack_ptr(uint64_t v)
            {
                uint32_t slot = static_cast<uint32_t>(v & SLOT_MASK);
                if ((slot == 0) || (slot >= MAX_SLOTS)) return nullptr;

                const uint32_t handle_generation = unpack_generation(v);
                
                uint32_t block_idx = slot_to_block_index(slot);
                uint32_t offset = slot_to_block_offset(slot);
                slot_block* block = blocks_[block_idx].load(memory_order_acquire);
                if (block == nullptr) return nullptr;

                const uint32_t table_generation = block->slot_generation_[offset].load(memory_order_acquire);
                if ((handle_generation == 0) || (table_generation != handle_generation))
                {
                    return nullptr;
                }

                return block->slot_table_[offset].load(memory_order_acquire);
            }

            static constexpr bool is_tombstoned_val(uint64_t v)
            {
                return (v & TOMBSTONE_BIT) != 0;
            }

            static constexpr uint32_t unpack_generation(uint64_t v)
            {
                return static_cast<uint32_t>((v >> GENERATION_SHIFT) & GENERATION_MASK);
            }

#ifdef __MINIMAL_STD_TEST__
        public:
            static uint32_t debug_slot_high_water_mark()
            {
                return high_water_slot_.load(memory_order_relaxed);
            }

            static void debug_reset_slot_high_water_mark()
            {
                high_water_slot_.store(0, memory_order_relaxed);
            }

        private:
#endif

        public:
            atomic_forward_link(const atomic_forward_link &) = delete;
            atomic_forward_link &operator=(const atomic_forward_link &) = delete;
            atomic_forward_link(atomic_forward_link &&) = delete;
            atomic_forward_link &operator=(atomic_forward_link &&) = delete;

            atomic_forward_link()
            {
                packed_.store(0, memory_order_relaxed);
            }

            ~atomic_forward_link() = default;

            //  Store a pointer (only for nodes not yet visible to other threads)

            void set(T *ptr)
            {
                packed_.store(pack(ptr, false), memory_order_release);
            }

            //  Load just the pointer

            T *get_reference() const
            {
                return unpack_ptr(packed_.load(memory_order_acquire));
            }

            //  Atomic snapshot of pointer and tombstone state

            T *get(bool &is_tombstoned) const
            {
                const uint64_t v = packed_.load(memory_order_acquire);
                is_tombstoned = is_tombstoned_val(v);
                return unpack_ptr(v);
            }

            //  Mark this link as tombstoned (CAS loop, preserves pointer)
            //
            //  We manipulate the raw bits directly, preserving slot-index and
            //  generation while only toggling the tombstone bit.

            void soft_delete()
            {
                while (true)
                {
                    uint64_t current = packed_.load(memory_order_acquire);

                    if (is_tombstoned_val(current))
                    {
                        return;
                    }

                    const uint64_t desired = current | TOMBSTONE_BIT;

                    if (packed_.compare_exchange_strong(current, desired, memory_order_acq_rel, memory_order_acquire))
                    {
                        return;
                    }
                }
            }

            //  CAS: succeeds only if current pointer == expected_value and link is
            //  not tombstoned.  On success, atomically sets the pointer to new_value
            //  and optionally marks the link tombstoned (mark_tombstoned == true).
            //
            //  We compare handle identity (slot + generation) directly from the
            //  packed value and expected pointer metadata. This guarantees stale
            //  slot reuse does not falsely match expected_value.

            bool compare_exchange_strong(T *expected_value, T *new_value, bool mark_tombstoned = false)
            {
                uint64_t current = packed_.load(memory_order_acquire);

                const uint32_t expected_slot = pointer_slot_or_zero(expected_value);
                const uint32_t expected_generation = pointer_generation_or_zero(expected_value);

                if (((current & SLOT_MASK) != static_cast<uint64_t>(expected_slot)) ||
                    (unpack_generation(current) != expected_generation) ||
                    is_tombstoned_val(current))
                {
                    return false;
                }

                const uint64_t desired = pack(new_value, mark_tombstoned);

                return packed_.compare_exchange_strong(current, desired, memory_order_acq_rel, memory_order_acquire);
            }

        private:
            atomic<uint64_t> packed_;
        };

        template <typename KeyType, typename ValueType, size_t NumCPUs, int32_t MAX_LEVELS = DEFAULT_MAX_LEVELS> //  NumCPUs: CPU slot array size (mandatory — sizes cpu_slots_); MAX_LEVELS must be signed as we iterate down to and include index 0
        class skip_list
        {
        private:
            static constexpr uint32_t MAX_INSERT_LEVEL0_RETRIES = 1024;
            static constexpr uint32_t MAX_INSERT_UPPER_LEVEL_RETRIES = 256;
            static constexpr uint32_t MAX_REMOVE_MARK_RETRIES_PER_LEVEL = 256;
            static constexpr uint32_t MAX_REMOVE_BOTTOM_RETRIES = 1024;
            static constexpr uint32_t MAX_INSERT_LOCAL_ASSIST_FAILURES = 8;
            static constexpr uint32_t MAX_REMOVE_LOCAL_ASSIST_FAILURES = 8;
            static constexpr uint32_t BACKOFF_MAX_RELAX_SPINS = 32;
            static constexpr uint64_t EPOCH_RECLAIM_LAG = 2;
            static constexpr uint32_t EPOCH_RECLAIM_THROTTLE_INITIAL = 16;
            static constexpr uint32_t EPOCH_RECLAIM_THROTTLE_MIN = 4;
#ifdef __MINIMAL_STD_TEST__
            static constexpr uint32_t DEBUG_MAX_VALIDATION_STEPS = 1000000;
#endif

            enum class unlink_state : uint8_t
            {
                ACTIVE,
                FULLY_UNLINKED
            };

            struct alignas(64) SkipNode
            {
                // Constructor for standard nodes
                SkipNode(const KeyType k, const ValueType &v, const int next_node_size) : key(k), value(v), top_level(next_node_size)
                {
                    const auto slot = atomic_forward_link<SkipNode>::allocate_slot(this);
                    internal_slot_ = slot.slot;
                    internal_generation_ = slot.generation;
                    if (internal_slot_ != 0)
                    {
                        intialize_next_nodes(next_node_size, nullptr);
                    }
                }

                // Constructor for sentinel nodes head and NIL
                SkipNode(const KeyType k, const int next_node_size, SkipNode *next_node_target) : key(k), top_level(next_node_size)
                {
                    const auto slot = atomic_forward_link<SkipNode>::allocate_slot(this);
                    internal_slot_ = slot.slot;
                    internal_generation_ = slot.generation;
                    intialize_next_nodes(next_node_size, next_node_target);
                }

                ~SkipNode()
                {
                    atomic_forward_link<SkipNode>::free_slot(internal_slot_);
                }

                SkipNode(const SkipNode &) = delete;
                SkipNode &operator=(const SkipNode &) = delete;
                SkipNode(SkipNode &&) = delete;
                SkipNode &operator=(SkipNode &&) = delete;

                void intialize_next_nodes(const int next_node_size, SkipNode *next_node_target)
                {
                    for (auto i = 0; i != next_node_size; ++i)
                    {
                        next_node[i].set(next_node_target);
                    }
                }

                // Hot metadata: checked by every traversing thread — placed first
                // so they share the first cache line with key/value.
                atomic<int32_t> upper_levels_remaining_{0};
                atomic<uint8_t> unlink_state_{static_cast<uint8_t>(unlink_state::ACTIVE)};
                atomic<bool> retirement_enqueued_{false};

                uint32_t internal_slot_;
                uint32_t internal_generation_;
                KeyType key;
                ValueType value;
                int top_level;

                SkipNode *retired_next = nullptr;
                uint64_t retired_epoch_ = 0;

                // Forward links: each packs slot generation + slot index + tombstone in 64 bits.
                // Placed after hot metadata to avoid polluting the first cache line.
                array<atomic_forward_link<SkipNode>, MAX_LEVELS + 1> next_node;
            };

            using slot_policy_type = bare_metal_cpu_slot_policy<SkipNode, NumCPUs, EPOCH_RECLAIM_THROTTLE_INITIAL, EPOCH_RECLAIM_THROTTLE_MIN>;
            using epoch_reclaimer_type = epoch_reclaimer_core<slot_policy_type, NumCPUs, EPOCH_RECLAIM_LAG>;


        public:

        using key_type = KeyType;
        using value_type = ValueType;
        
        using allocator_type = allocator<value_type>;

            skip_list()
                : epoch_reclaimer_(slot_policy_)
            {
                NIL = new SkipNode(std::numeric_limits<KeyType>::max(), MAX_LEVELS + 1, nullptr);
                head = new SkipNode(std::numeric_limits<KeyType>::min(), MAX_LEVELS + 1, NIL);
            }

            ~skip_list()
            {
                SkipNode *current_node = head->next_node[0].get_reference();

                while (current_node != NIL)
                {
                    SkipNode *next_node = current_node->next_node[0].get_reference();

                    if (!current_node->retirement_enqueued_.load(memory_order_acquire))
                    {
                        delete current_node;
                    }

                    current_node = next_node;
                }

                reclaim_all_retired_nodes();

                delete head;
                delete NIL;
            };

            ValueType *find(const KeyType search_key)
            {
                epoch_read_section_guard read_guard(this);

                bool is_tombstoned = false;
                SkipNode *pred = head, *curr = nullptr, *succ = nullptr;

                // traverse from top of head
                for (int level = MAX_LEVELS; level >= 0; --level)
                {
                    curr = pred->next_node[level].get_reference();

                    while (true)
                    {
                        if (curr == nullptr)
                        {
                            // Corrupted/null link observed; treat as end-of-list sentinel.
                            curr = NIL;
                            break;
                        }

                        succ = curr->next_node[level].get(is_tombstoned);

                        while (is_tombstoned)
                        {
                            SkipNode *tombstoned_node = curr;
                            curr = succ;

                            if (curr == nullptr)
                            {
                                curr = NIL;
                                is_tombstoned = false;
                                break;
                            }

                            succ = curr->next_node[level].get(is_tombstoned);

                            if (level > 0)
                            {
                                //  Upper level: CAS out the tombstone and decrement
                                //  the counter so level-0 knows when it's safe.

                                if (pred->next_node[level].compare_exchange_strong(tombstoned_node, curr))
                                {
                                    tombstoned_node->upper_levels_remaining_.fetch_sub(1, memory_order_release);
                                }
                            }
                            else
                            {
                                //  Level 0: unlink only when all upper levels are done.

                                if (tombstoned_node->upper_levels_remaining_.load(memory_order_acquire) <= 0)
                                {
                                    if (pred->next_node[0].compare_exchange_strong(tombstoned_node, curr))
                                    {
                                        tombstoned_node->unlink_state_.store(static_cast<uint8_t>(unlink_state::FULLY_UNLINKED), memory_order_release);
                                        retire_node(tombstoned_node, read_guard.cpu_slot_);
                                    }
                                }
                            }
                        }

                        //  Move down the skip list

                        if (curr->key < search_key)
                        {
                            pred = curr;
                            curr = succ;
                        }
                        else
                        {
                            break;
                        }
                    }
                }

                return ((curr != nullptr) && (curr->key == search_key) ? &curr->value : nullptr);
            }

            bool insert(const KeyType key, const ValueType &value)
            {
                epoch_read_section_guard read_guard(this);

                uint32_t insert_level0_retry_count = 0;
                uint32_t insert_level0_backoff = 0;
                uint32_t insert_upper_level_backoff = 0;

                int top_level = random_level();

                SkipNode *preds[MAX_LEVELS + 1];
                SkipNode *succs[MAX_LEVELS + 1];

                SkipNode *new_node = nullptr;

            RETRY_INSERT:
                while (true)
                {
                    FindResult found = find_with_nodelists(key, preds, succs, read_guard.cpu_slot_);

                    if (found == FindResult::FOUND)
                    {
                        delete new_node;
                        return false;
                    }
                    else
                    {
                        if (new_node == nullptr)
                        {
                            new_node = new SkipNode(key, value, top_level);
                            if (new_node->internal_slot_ == 0)
                            {
                                delete new_node;
                                return false;
                            }
                        }

                        for (auto level = 1; level < top_level; ++level)
                        {
                            auto succ = succs[level];
                            new_node->next_node[level].set(succ);
                        }

                        auto pred = preds[0];
                        auto succ = succs[0];

                        new_node->next_node[0].set(succ);

                        while (true)
                        {
                            if (pred->next_node[0].compare_exchange_strong(succ, new_node))
                            {
                                insert_level0_backoff = 0;
                                break;
                            }

                            ++insert_level0_retry_count;

                            if (insert_level0_retry_count >= MAX_INSERT_LEVEL0_RETRIES)
                            {
                                delete new_node;
                                return false;
                            }

                            backoff(insert_level0_backoff, read_guard.cpu_slot_);

                            // Rightward traversal on level 0 upon CAS failure
                            bool is_tombstoned = false;

                            pred->next_node[0].get(is_tombstoned);
                            if (is_tombstoned)
                            {
                                goto RETRY_INSERT;
                            }

                            bool soft_deleted = false;
                            uint32_t local_assist_failures = 0;

                            SkipNode *curr = pred->next_node[0].get_reference();
                            
                            while (true)
                            {
                                if (curr == nullptr)
                                {
                                    // Stale handle observed during retry traversal.
                                    // Restart to refresh preds/succs from a clean search.
                                    goto RETRY_INSERT;
                                }

                                succ = curr->next_node[0].get(is_tombstoned);

                                while (is_tombstoned)
                                {
                                    SkipNode *tombstoned_node = curr;

                                    if (curr->key == key)
                                    {
                                        soft_deleted = true;
                                    }

                                    curr = succ;

                                    if (curr == nullptr)
                                    {
                                        // Stale handle observed while helping tombstone unlink.
                                        goto RETRY_INSERT;
                                    }

                                    succ = curr->next_node[0].get(is_tombstoned);

                                    if (tombstoned_node->upper_levels_remaining_.load(memory_order_acquire) <= 0)
                                    {
                                        if (pred->next_node[0].compare_exchange_strong(tombstoned_node, curr))
                                        {
                                            tombstoned_node->unlink_state_.store(static_cast<uint8_t>(unlink_state::FULLY_UNLINKED), memory_order_release);
                                            retire_node(tombstoned_node, read_guard.cpu_slot_);
                                        }
                                    }
                                    else
                                    {
                                        ++local_assist_failures;

                                        if (local_assist_failures >= MAX_INSERT_LOCAL_ASSIST_FAILURES)
                                        {
                                            goto RETRY_INSERT;
                                        }

                                        backoff(insert_level0_backoff, read_guard.cpu_slot_);
                                    }
                                }

                                if (curr->key < key)
                                {
                                    pred = curr;
                                    curr = succ;
                                }
                                else
                                {
                                    break;
                                }
                            }

                            if ((curr->key == key) || soft_deleted)
                            {
                                delete new_node;
                                return false;
                            }

                            preds[0] = pred;
                            succs[0] = curr;
                            succ = curr; // New expected reference for CAS failure retry
                            new_node->next_node[0].set(succ);
                        }

                        for (auto level = 1; level < top_level; ++level)
                        {
                            uint32_t upper_level_retry_count = 0;

                            while (true)
                            {
                                pred = preds[level];
                                succ = succs[level];

                                if (pred->next_node[level].compare_exchange_strong(succ, new_node))
                                {
                                    new_node->upper_levels_remaining_.fetch_add(1, memory_order_release);
                                    insert_upper_level_backoff = 0;
                                    break;
                                }

                                ++upper_level_retry_count;

                                if (upper_level_retry_count >= MAX_INSERT_UPPER_LEVEL_RETRIES)
                                {
                                    break;
                                }

                                backoff(insert_upper_level_backoff, read_guard.cpu_slot_);

                                find_with_nodelists(key, preds, succs, read_guard.cpu_slot_); // CAS failed for upper level, search node to update preds and succs
                            }
                        }

                        return true;
                    }
                }
            }

            bool remove(const KeyType key)
            {
                epoch_read_section_guard read_guard(this);

                SkipNode *preds[MAX_LEVELS + 1];
                SkipNode *succs[MAX_LEVELS + 1];
                SkipNode *succ;

            RETRY_REMOVE:
                while (true)
                {
                    FindResult found = find_with_nodelists(key, preds, succs, read_guard.cpu_slot_);

                    if (found != FindResult::FOUND)
                    {
                        return false; // nothing to delete
                    }
                    else
                    {
                        auto node_to_remove = succs[0];

                        //  Mark as deleted on higher levels

                        bool is_tombstoned = false;

                        for (auto level = node_to_remove->top_level - 1; level >= 1; --level)
                        {
                            succ = node_to_remove->next_node[level].get(is_tombstoned);
                            uint32_t mark_retry_count = 0;
                            uint32_t mark_retry_backoff = 0;

                            while (!is_tombstoned)
                            {
                                node_to_remove->next_node[level].soft_delete();
                                succ = node_to_remove->next_node[level].get(is_tombstoned);

                                ++mark_retry_count;

                                if (mark_retry_count >= MAX_REMOVE_MARK_RETRIES_PER_LEVEL)
                                {
                                    goto RETRY_REMOVE;
                                }

                                backoff(mark_retry_backoff, read_guard.cpu_slot_);
                            }
                        }

                        //  Bottom level

                        is_tombstoned = false;
                        succ = node_to_remove->next_node[0].get(is_tombstoned);
                        uint32_t bottom_retry_count = 0;
                        uint32_t bottom_retry_backoff = 0;

                        auto pred = preds[0];

                        while (true)
                        {
                            bool success = node_to_remove->next_node[0].compare_exchange_strong(succ, succ, true);
                            succ = node_to_remove->next_node[0].get(is_tombstoned);

                            if (success)
                            {
                                // this thread soft deleted the node

                                if (node_to_remove->upper_levels_remaining_.load(memory_order_acquire) <= 0)
                                {
                                    if (pred->next_node[0].compare_exchange_strong(node_to_remove, succ))
                                    {
                                        node_to_remove->unlink_state_.store(static_cast<uint8_t>(unlink_state::FULLY_UNLINKED), memory_order_release);
                                        retire_node(node_to_remove, read_guard.cpu_slot_);
                                    }
                                }

                                auto &slot_state = slot_policy_.slot(read_guard.cpu_slot_);

                                slot_state.increment_reclaim_throttle();

                                if (slot_state.reclaim_throttle_triggered())
                                {
                                    auto [nodes_freed, epoch_advanced] = advance_and_reclaim(read_guard.cpu_slot_);
                                    slot_state.adapt_reclaim_throttle(nodes_freed, epoch_advanced);
                                }

                                return true;
                            }
                            else if (is_tombstoned)
                            {
                                // another thread already soft deleted the node

                                return false;
                            }

                            ++bottom_retry_count;

                            if (bottom_retry_count >= MAX_REMOVE_BOTTOM_RETRIES)
                            {
                                // Avoid livelock under heavy contention on the same key.
                                // A future operation can retry from a fresh call boundary.
                                return false;
                            }

                            backoff(bottom_retry_backoff, read_guard.cpu_slot_);

                            bool soft_deleted = false;
                            uint32_t local_assist_failures = 0;
                            SkipNode *curr = pred->next_node[0].get_reference();
                            
                            while (true)
                            {
                                succ = curr->next_node[0].get(is_tombstoned);

                                while (is_tombstoned)
                                {
                                    SkipNode *tombstoned_node = curr;
                                    if (curr->key == key) { soft_deleted = true; }
                                    curr = succ;
                                    succ = curr->next_node[0].get(is_tombstoned);

                                    if (tombstoned_node->upper_levels_remaining_.load(memory_order_acquire) <= 0)
                                    {
                                        if (pred->next_node[0].compare_exchange_strong(tombstoned_node, curr))
                                        {
                                            tombstoned_node->unlink_state_.store(static_cast<uint8_t>(unlink_state::FULLY_UNLINKED), memory_order_release);
                                            retire_node(tombstoned_node, read_guard.cpu_slot_);
                                        }
                                    } else {
                                        ++local_assist_failures;

                                        if (local_assist_failures >= MAX_REMOVE_LOCAL_ASSIST_FAILURES)
                                        {
                                            // Avoid spinning forever in local assist when
                                            // upper-level progress does not converge.
                                            return false;
                                        }

                                        backoff(bottom_retry_backoff, read_guard.cpu_slot_);
                                    }
                                }
                                if (curr->key < key) {
                                    pred = curr;
                                    curr = succ;
                                } else {
                                    break;
                                }
                            }
                            if (soft_deleted || curr->key != key) {
                                return false;
                            }
                            node_to_remove = curr;
                            succ = curr->next_node[0].get(is_tombstoned);
                        }
                    }
                }
            }

            uint32_t size() const
            {
                epoch_read_section_guard read_guard(this);

                auto current_node = head->next_node[0].get_reference();

                uint32_t size = 0;
                bool node_is_tombstoned = false;

                while (current_node->key != std::numeric_limits<KeyType>::max())
                {
                    current_node->next_node[0].get(node_is_tombstoned);

                    if (!node_is_tombstoned)
                    {
                        ++size;
                    }

                    current_node = current_node->next_node[0].get_reference();
                }

                return size;
            }

