#pragma once

#include <algorithm>
#include <array>
#include <atomic>
#include <optional>

namespace MINIMAL_STD_NAMESPACE
{
    template <size_t SIZE_IN_BITS>
        requires(SIZE_IN_BITS >= 128)
    class binary_semaphore_array
    {
    public:
        binary_semaphore_array()
        {
            for (size_t i = 0; i < SIZE_IN_BITS / 64; i++)
            {
                bits_[i] = 0;
            }
        }

        size_t size() const
        {
            return SIZE_IN_BITS;
        }

        size_t bits_set() const
        {
            return bits_set_;
        }

        bool acquire(const size_t bit_index)
        {
            if (bit_index >= SIZE_IN_BITS)
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

            //  We may need to retry the compare_exchange_strong operation if another thread
            //      has modified any of the other 63 bits in the uint64_t that we are modifying.

        RETRY:

            uint64_t current_value = bits_[offset].load(memory_order_seq_cst);

            //  Convert to little endian for bit manipulation - otherwise we have a discontinuity across the uint64_t boundaries

            uint64_t current_value_big_endian = __builtin_bswap64(bits_[offset].load(memory_order_seq_cst));

            if ((current_value_big_endian & (0x8000000000000000 >> bit)) != 0)
            {
                return false;
            }

            //  Set the bit and return to big endian

            uint64_t new_value = __builtin_bswap64(current_value_big_endian | (0x8000000000000000 >> bit));

            //  Try to set the bit.  If ths fails, it does not necessarily mean another thread got this
            //      bit - just that a bit in the uint64_t was modified.  The retry will fail if the bit
            //      was set by another thread - otherwise we will try again in this thread.

            if (!bits_[offset].compare_exchange_strong(current_value, new_value, memory_order_seq_cst))
            {
                goto RETRY;
            }

            bits_set_++;

            return true;
        }

        bool release(const size_t bit_index)
        {
            if (bit_index >= SIZE_IN_BITS)
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

        RETRY:

            uint64_t current_value = bits_[offset].load(memory_order_seq_cst);

            uint64_t current_value_big_endian = __builtin_bswap64(bits_[offset].load(memory_order_seq_cst));

            if ((current_value_big_endian & (0x8000000000000000 >> bit)) == 0)
            {
                return false;
            }

            //  We need to taake the one's complement of the single bit mask so we can clear the bit.

            uint64_t new_value = __builtin_bswap64(current_value_big_endian & ~(0x8000000000000000 >> bit));

            if (!bits_[offset].compare_exchange_strong(current_value, new_value, memory_order_seq_cst))
            {
                goto RETRY;
            }

            bits_set_--;

            return true;
        }

        bool is_acquired(const size_t bit_index) const
        {
            if (bit_index >= SIZE_IN_BITS)
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

            return (__builtin_bswap64(bits_[offset].load(memory_order_seq_cst)) & (0x8000000000000000 >> bit)) != 0;
        }

        bool acquire_block(const size_t bit_index, const uint32_t block_length_in_bits)
        {
            //  Blocks are limited to 16 bits in length

            if ((block_length_in_bits == 0) || (block_length_in_bits > 16) || (bit_index + block_length_in_bits > SIZE_IN_BITS))
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

            //  If the block does not cross a uint64_t boundary then we use the bits_ array

            if (bit + block_length_in_bits < 64)
            {
                uint64_t current_value = bits_[offset].load(memory_order_seq_cst);

                uint64_t current_value_big_endian = __builtin_bswap64(bits_[offset].load(memory_order_seq_cst));

                if ((current_value_big_endian & (bit_blocks[block_length_in_bits] >> bit)) != 0)
                {
                    return false;
                }

                uint64_t new_value = __builtin_bswap64(current_value_big_endian | (bit_blocks[block_length_in_bits] >> bit));

                bool success = bits_[offset].compare_exchange_strong(current_value, new_value, memory_order_seq_cst);

                if (success)
                {
                    bits_set_ += block_length_in_bits;
                }

                return success;
            }

            //  The block spans a uint64_t boundary, so we need to use the offset_bits array and adjust
            //      the offset and bit values accordingly.

            array<atomic<uint64_t>, (SIZE_IN_BITS / 64) - 1> &offset_bits = *((array<atomic<uint64_t>, (SIZE_IN_BITS / 64) - 1> *)((char *)&bits_ + 4));

            uint64_t current_value = offset_bits[offset].load(memory_order_seq_cst);

            uint64_t current_value_big_endian = __builtin_bswap64(offset_bits[offset].load(memory_order_seq_cst));

            if ((current_value_big_endian & (bit_blocks[block_length_in_bits] >> (bit - 32))) != 0)
            {
                return false;
            }

            uint64_t new_value = __builtin_bswap64(current_value_big_endian | (bit_blocks[block_length_in_bits] >> (bit - 32)));

            bool success = offset_bits[offset].compare_exchange_strong(current_value, new_value, memory_order_seq_cst);

            if (success)
            {
                bits_set_ += block_length_in_bits;
            }

            return success;
        }

        bool release_block(const size_t bit_index, const uint32_t block_length_in_bits)
        {
            //  Blocks are limited to 16 bits in length

            if ((block_length_in_bits == 0) || (block_length_in_bits > 16) || (bit_index + block_length_in_bits > SIZE_IN_BITS))
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

            //  If the block does not cross a uint64_t boundary then we use the bits_ array

            if (bit + block_length_in_bits < 64)
            {
                uint64_t current_value = bits_[offset].load(memory_order_seq_cst);

                uint64_t current_value_big_endian = __builtin_bswap64(bits_[offset].load(memory_order_seq_cst));

                if ((current_value_big_endian & (bit_blocks[block_length_in_bits] >> bit)) == 0)
                {
                    return true; //  Already released
                }

                uint64_t new_value = __builtin_bswap64(current_value_big_endian & ~(bit_blocks[block_length_in_bits] >> bit));

                bool success = bits_[offset].compare_exchange_strong(current_value, new_value, memory_order_seq_cst);

                if (success)
                {
                    bits_set_ -= block_length_in_bits;
                }

                return success;
            }

            //  The block spans a uint64_t boundary, so we need to use the offset_bits_ array and adjust
            //      the offset and bit values accordingly.

            array<atomic<uint64_t>, (SIZE_IN_BITS / 64) - 1> &offset_bits = *((array<atomic<uint64_t>, (SIZE_IN_BITS / 64) - 1> *)((char *)&bits_ + 4));

            uint64_t current_value = offset_bits[offset].load(memory_order_seq_cst);

            uint64_t current_value_big_endian = __builtin_bswap64(offset_bits[offset].load(memory_order_seq_cst));

            if ((current_value_big_endian & (bit_blocks[block_length_in_bits] >> (bit - 32))) == 0)
            {
                return true; //  Already released
            }

            uint64_t new_value = __builtin_bswap64(current_value_big_endian & ~(bit_blocks[block_length_in_bits] >> (bit - 32)));

            bool success = offset_bits[offset].compare_exchange_strong(current_value, new_value, memory_order_seq_cst);

            if (success)
            {
                bits_set_ -= block_length_in_bits;
            }

            return success;
        }

        minstd::optional<size_t> acquire_next_empty_block(const uint32_t block_length_in_bits, const int32_t search_hint = -1)
        {
            //  Blocks are limited to 16 bits in length

            if ((block_length_in_bits == 0) || (block_length_in_bits > 16))
            {
                return false;
            }

            //  Start the search at the hint, if provided - otherwise from the last hint location

            uint32_t start_search = search_hint >= 0 ? search_hint : search_hint_.load(memory_order_seq_cst);

            start_search = start_search >= SIZE_IN_BITS ? 0 : start_search;

            //  Search for an empty block of the correct size

            uint64_t mask = bit_blocks[block_length_in_bits];

            bool found = false;
            uint32_t index = 0;

            for (size_t i = 0; i < SIZE_IN_BITS;)
            {
                index = (start_search + i) % SIZE_IN_BITS;

                const size_t offset = index / 64;
                const size_t bit = index % 64;

                //  If the block does not cross a uint64_t boundary then we use the bits_ array

                if ((bit + block_length_in_bits < 64) || (offset == (SIZE_IN_BITS / 64) - 1))
                {
                    uint64_t current_value_big_endian = __builtin_bswap64(bits_[offset].load(memory_order_seq_cst));

                    for (size_t j = bit; j + block_length_in_bits <= 64; j++)
                    {
                        if ((current_value_big_endian & (mask >> j)) == 0)
                        {
                            found = true;
                            break;
                        }

                        i++;
                        index++;
                    }

                    if (found)
                    {
                        break;
                    }

                    //  If we are at the end of the array, skip forward to the beginning

                    if (offset == (SIZE_IN_BITS / 64) - 1)
                    {
                        i += block_length_in_bits - 1;
                    }
                }
                else
                {
                    //  The block spans a uint64_t boundary, so we need to use the offset_bits_ array and adjust
                    //      the offset and bit values accordingly.

                    array<atomic<uint64_t>, (SIZE_IN_BITS / 64) - 1> &offset_bits = *((array<atomic<uint64_t>, (SIZE_IN_BITS / 64) - 1> *)((char *)&bits_ + 4));

                    uint64_t current_value_big_endian = __builtin_bswap64(offset_bits[offset].load(memory_order_seq_cst));

                    for (size_t j = bit; j - block_length_in_bits <= 64; j++)
                    {
                        if ((current_value_big_endian & (mask >> (j - 32))) == 0)
                        {
                            found = true;
                            break;
                        }

                        i++;
                        index++;
                    }

                    if (found)
                    {
                        break;
                    }
                }
            }

            if (found && acquire_block(index, block_length_in_bits))
            {
                search_hint_ = index + block_length_in_bits;
                return index;
            }

            return minstd::optional<size_t>();
        }

    private:
        static constexpr uint64_t bit_blocks[] =
            {
                0x0000000000000000,
                0x8000000000000000, 0xC000000000000000, 0xE000000000000000, 0xF000000000000000,
                0xF800000000000000, 0xFC00000000000000, 0xFE00000000000000, 0xFF00000000000000,
                0xFF80000000000000, 0xFFC0000000000000, 0xFFE0000000000000, 0xFFF0000000000000,
                0xFFF8000000000000, 0xFFFC000000000000, 0xFFFE000000000000, 0xFFFF000000000000};

        array<atomic<uint64_t>, SIZE_IN_BITS / 64> bits_;

        atomic<int32_t> bits_set_ = 0;

        atomic<uint32_t> search_hint_ = 0;
    };
}