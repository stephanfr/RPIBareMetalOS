#pragma once

#include <algorithm>
#include <array>
#include <atomic>
#include <optional>

namespace MINIMAL_STD_NAMESPACE
{
    template <size_t SIZE_IN_BITS>
        requires(SIZE_IN_BITS >= 128)
    class binary_semaphore_array
    {
    public:
        binary_semaphore_array()
        {
            for (size_t i = 0; i < (SIZE_IN_BITS / 64) + 1; i++)
            {
                bits_[i] = 0;
            }
        }

        size_t size() const
        {
            return SIZE_IN_BITS;
        }

        size_t bits_set() const
        {
            return bits_set_;
        }

        bool acquire(const size_t bit_index)
        {
            if (bit_index >= SIZE_IN_BITS)
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

            //  We may need to retry the compare_exchange_strong operation if another thread
            //      has modified any of the other 63 bits in the uint64_t that we are modifying.

        RETRY:

            uint64_t current_value = bits_[offset].load(memory_order_acquire);

            //  Convert to little endian for bit manipulation - otherwise we have a discontinuity across the uint64_t boundaries

            uint64_t current_value_big_endian = __builtin_bswap64(current_value);

            if ((current_value_big_endian & (0x8000000000000000 >> bit)) != 0)
            {
                return false;
            }

            //  Set the bit and return to big endian

            uint64_t new_value = __builtin_bswap64(current_value_big_endian | (0x8000000000000000 >> bit));

            //  Try to set the bit.  If ths fails, it does not necessarily mean another thread got this
            //      bit - just that a bit in the uint64_t was modified.  The retry will fail if the bit
            //      was set by another thread - otherwise we will try again in this thread.

            if (!bits_[offset].compare_exchange_strong(current_value, new_value, memory_order_acq_rel, memory_order_acquire))
            {
                goto RETRY;
            }

            bits_set_++;

            return true;
        }

        bool release(const size_t bit_index)
        {
            if (bit_index >= SIZE_IN_BITS)
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

        RETRY:

            uint64_t current_value = bits_[offset].load(memory_order_acquire);

            uint64_t current_value_big_endian = __builtin_bswap64(current_value);

            if ((current_value_big_endian & (0x8000000000000000 >> bit)) == 0)
            {
                return false;
            }

            //  We need to taake the one's complement of the single bit mask so we can clear the bit.

            uint64_t new_value = __builtin_bswap64(current_value_big_endian & ~(0x8000000000000000 >> bit));

            if (!bits_[offset].compare_exchange_strong(current_value, new_value, memory_order_acq_rel, memory_order_acquire))
            {
                goto RETRY;
            }

            bits_set_--;

            return true;
        }

        bool is_acquired(const size_t bit_index) const
        {
            if (bit_index >= SIZE_IN_BITS)
            {
                return false;
            }

            const size_t offset = bit_index / 64;
            const size_t bit = bit_index % 64;

            return (__builtin_bswap64(bits_[offset].load(memory_order_seq_cst)) & (0x8000000000000000 >> bit)) != 0;
        }

        bool acquire_block(const size_t bit_index, const size_t block_length_in_bits)
        {
            //  Blocks are limited to 16 bits in length

            if ((block_length_in_bits == 0) || (block_length_in_bits > 16) || (bit_index + block_length_in_bits > SIZE_IN_BITS))
            {
                return false;
            }

            //  Move to the closest 32-bit boundary.  This will allow us to span the uint64_t boundaries without
            //      special case handling.  The code could be compressed a bit in terms of lines and operations,
            //      but this is more readable and the optimizer will take care of any verbosity.
            //
            //  NB: '& 0x000000000000001F' is the same as '% 32' - optimizer probably alredy does this but no problem being explicit.

            size_t offset = bit_index / 32;
            atomic<uint64_t> *block = (atomic<uint64_t> *)((atomic<uint32_t> *)&bits_ + offset);
            uint64_t mask = bit_blocks[block_length_in_bits] >> (((offset & 0x0000000000000001) == 0 ? bit_index : (bit_index - 32)) & 0x000000000000001F);

            uint64_t current_value = block->load(memory_order_acquire);
            uint64_t current_value_big_endian = __builtin_bswap64(current_value);

            if ((current_value_big_endian & mask) == 0)
            {
                uint64_t next_value = __builtin_bswap64(current_value_big_endian | mask);

                if (block->compare_exchange_strong(current_value, next_value, memory_order_acq_rel, memory_order_acquire))
                {
                    bits_set_.fetch_add(block_length_in_bits, memory_order_acq_rel);
                    return true;
                }
            }

            return false;
        }

        bool release_block(const size_t bit_index, const uint32_t block_length_in_bits)
        {
            //  Blocks are limited to 16 bits in length

            if ((block_length_in_bits == 0) || (block_length_in_bits > 16) || (bit_index + block_length_in_bits > SIZE_IN_BITS))
            {
                return false;
            }

            //  Move to the closest 32-bit boundary.  This will allow us to span the uint64_t boundaries without
            //      special case handling.  The code could be compressed a bit in terms of lines and operations,
            //      but this is more readable and the optimizer will take care of any verbosity.
            //
            //  NB: '& 0x000000000000001F' is the same as '% 32' - optimizer probably alredy does this but no problem being explicit.

            size_t offset = bit_index / 32;
            atomic<uint64_t> *block = (atomic<uint64_t> *)((atomic<uint32_t> *)&bits_ + offset);
            uint64_t mask = bit_blocks[block_length_in_bits] >> (((offset & 0x0000000000000001) == 0 ? bit_index : (bit_index - 32)) & 0x000000000000001F);

            uint64_t current_value = block->load(memory_order_acquire);
            uint64_t current_value_big_endian = __builtin_bswap64(current_value);

            if ((current_value_big_endian & mask) == 0)
            {
                return true; //  Already released
            }

            uint64_t next_value = __builtin_bswap64(current_value_big_endian & ~mask);

            if (block->compare_exchange_strong(current_value, next_value, memory_order_acq_rel, memory_order_acquire))
            {
                bits_set_.fetch_add(-block_length_in_bits, memory_order_acq_rel);
                return true;
            }

            return false;
        }

        minstd::optional<size_t> acquire_next_empty_block(const uint32_t block_length_in_bits, const int32_t search_hint = -1)
        {
            //  Blocks are limited to 16 bits in length

            if ((block_length_in_bits == 0) || (block_length_in_bits > 16))
            {
                return false;
            }

            //  Start the search at the hint, if provided - otherwise from the last hint location

            uint32_t start_search = ((search_hint >= 0 ? search_hint : search_hint_.load(memory_order_acquire)) / 8) * 8;

            start_search = start_search >= SIZE_IN_BITS ? 0 : start_search;

            //  Search for an empty block of the correct size

            bool found = false;
            uint32_t index = 0;

            uint8_t *byte_array = (uint8_t *)&bits_;

            for (size_t i = 0; i < SIZE_IN_BITS;)
            {
                uint32_t offset = ((start_search + i) % SIZE_IN_BITS) / 8;

                if ((offset * 8) + block_length_in_bits >= SIZE_IN_BITS)
                {
                    i += 8 * (SIZE_IN_BITS / 8 - offset);
                    continue;
                }

                if (*(byte_array + offset) == 0xFF)
                {
                    i += 8;
                    continue;
                }

                uint64_t mask = bit_blocks[block_length_in_bits];
                uint64_t current_value = *((uint64_t *)(byte_array + offset));
                uint64_t current_value_big_endian = __builtin_bswap64(current_value);

                size_t j = 0;

                for (; j < 16; j++)
                {
                    if ((current_value_big_endian & mask) == 0)
                    {
                        found = true;
                        break;
                    }

                    mask = mask >> 1;
                }

                i += j;

                if (found)
                {
                    index = (start_search + i) % SIZE_IN_BITS;

                    if (acquire_block(index, block_length_in_bits))
                    {
                        search_hint_.store(index + block_length_in_bits, memory_order_release);
                        return index;
                    }

                    i += block_length_in_bits;
                    found = false;
                }
            }

            return minstd::optional<size_t>();
        }

    private:
        static constexpr uint64_t bit_blocks[] =
            {
                0x0000000000000000,
                0x8000000000000000, 0xC000000000000000, 0xE000000000000000, 0xF000000000000000,
                0xF800000000000000, 0xFC00000000000000, 0xFE00000000000000, 0xFF00000000000000,
                0xFF80000000000000, 0xFFC0000000000000, 0xFFE0000000000000, 0xFFF0000000000000,
                0xFFF8000000000000, 0xFFFC000000000000, 0xFFFE000000000000, 0xFFFF000000000000};

        //  Pad the array by one extra uint64_t to allow the mask to safely slide past the end of the array
        //      to avoid a special case in the search and avoid a seg fault.

        alignas(64) array<atomic<uint64_t>, (SIZE_IN_BITS / 64) + 1> bits_;

        atomic<uint32_t> search_hint_ = 0;
        atomic<int32_t> bits_set_ = 0;
    };
}